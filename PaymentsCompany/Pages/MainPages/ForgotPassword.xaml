<Page x:Class="PaymentsCompany.Pages.MainPages.ForgotPassword"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:PaymentsCompany.Pages.MainPages"
      mc:Ignorable="d" 
      d:DesignHeight="1080" d:DesignWidth="1920"
      Title="ForgotPassword">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="47*"/>
            <RowDefinition Height="313*"/>
        </Grid.RowDefinitions>
        <Border Background="Gray">
            <TextBlock Text="Забыл логин или пароль" Name="ActionTBl"
                   FontSize="80" FontWeight="Bold"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"/>
        </Border>

        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Grid.Row="1">
            <Label Content="Почта"
                   FontSize="50"/>
            <TextBox Width="1000" Height="90" Name="EmailTB" FontSize="40">
                <TextBox.Template>
                    <ControlTemplate TargetType="TextBox">
                        <Border CornerRadius="30"
                            Background="White"
                            BorderBrush="Black"
                            BorderThickness="1">
                            <ScrollViewer Name="PART_ContentHost"
                                      VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </TextBox.Template>
            </TextBox>
            <Label Content="код" Margin="0,50,0,0"
               FontSize="50"/>
            <TextBox Width="1000" Height="90" Name="CodeTB" FontSize="40">
                <TextBox.Template>
                    <ControlTemplate TargetType="TextBox">
                        <Border CornerRadius="30"
                            Background="White"
                            BorderBrush="Black"
                            BorderThickness="1">
                            <ScrollViewer Name="PART_ContentHost"
                                      VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </TextBox.Template>
            </TextBox>
            <Button Margin="0,40,0,0" FontSize="60" BorderThickness="0" Name="AuthorizationBT" Click="AuthorizationBT_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Cursor="Hand"
                            Height="100"
                            Background="LightGreen"
                            BorderThickness="2"
                            BorderBrush="Black"
                            CornerRadius="20">
                            <Label Content="Войти" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            <Button Margin="0,40,0,0" FontSize="60" BorderThickness="0" Name="ForgotPasswordBT" Click="ForgotPasswordBT_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Cursor="Hand"
                            Height="70"
                            Background="White"
                            BorderThickness="2"
                            BorderBrush="Black"
                            CornerRadius="20">
                            <Label Content="У меня есть данные от аккаунта" FontSize="30" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>
    </Grid>
</Page>
