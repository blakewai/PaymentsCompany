<Page x:Class="PaymentsCompany.Pages.MainPages.Authorization"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:PaymentsCompany.Pages.MainPages"
      mc:Ignorable="d" 
      d:DesignHeight="1080" d:DesignWidth="1920"
      Title="Authorization">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="47*"/>
            <RowDefinition Height="313*"/>
        </Grid.RowDefinitions>
        <Border Background="Gray">
            <TextBlock Text="Вход" Name="ActionTBl"
                       FontSize="80" FontWeight="Bold"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
        </Border>

        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Grid.Row="1">
            <Label Content="Логин"
                       FontSize="50"/>
            <TextBox Width="1000" Height="90" Name="LoginTB" FontSize="40">
                <TextBox.Template>
                    <ControlTemplate TargetType="TextBox">
                        <Border CornerRadius="30"
                                Background="White"
                                BorderBrush="Black"
                                BorderThickness="1">
                            <ScrollViewer Name="PART_ContentHost"
                                          VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </TextBox.Template>
            </TextBox>
            <Label Content="Пароль" Margin="0,50,0,0"
                   FontSize="50"/>
            <PasswordBox Width="1000" Height="90" Name="PasswordPB" FontSize="40">
                <PasswordBox.Template>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border CornerRadius="30"
                                Background="White"
                                BorderBrush="Black"
                                BorderThickness="1">
                            <ScrollViewer Name="PART_ContentHost"
                                          VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </PasswordBox.Template>
            </PasswordBox>
            <TextBox Width="1000" Height="90" Name="PasswordTB" Visibility="Collapsed" FontSize="40">
                <TextBox.Template>
                    <ControlTemplate TargetType="TextBox">
                        <Border CornerRadius="30"
                                Background="White"
                                BorderBrush="Black"
                                BorderThickness="1">
                            <ScrollViewer Name="PART_ContentHost"
                                          VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </TextBox.Template>
            </TextBox>
            <Button Content="Показать пароль" FontSize="30" Background="{x:Null}" Name="PasswordVisibility" BorderThickness="0,0,0,3" Click="PasswordVisibility_Click"/>
            <Button Margin="0,40,0,0" FontSize="60" BorderThickness="0" Name="AuthorizationBT" Click="AuthorizationBT_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Cursor="Hand"
                                Height="100"
                                Background="LightGreen"
                                BorderThickness="2"
                                BorderBrush="Black"
                                CornerRadius="20">
                            <Label Content="Войти" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            <Button Margin="0,40,0,0" FontSize="60" BorderThickness="0" Name="ForgotPasswordBT" Click="ForgotPasswordBT_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Cursor="Hand"
                                Height="70"
                                Background="White"
                                BorderThickness="2"
                                BorderBrush="Black"
                                CornerRadius="20">
                            <Label Content="Забыл пароль" FontSize="30" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>
    </Grid>
</Page>